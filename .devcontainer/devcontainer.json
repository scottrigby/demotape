// Development container for the demotape repo itself. Eats our own dog
// food: pulls the published feature for system deps (Playwright, VHS,
// ttyd, FFmpeg, voice), then `pip install -e .` replaces the from-git
// demotape install with the live source under src/.
//
// Open this folder in VS Code with the Dev Containers extension, or:
//   devcontainer up --workspace-folder .
//   devcontainer exec --workspace-folder . demotape render demos/example.yaml
{
  "name": "demotape dev",
  "image": "mcr.microsoft.com/devcontainers/base:debian",

  "features": {
    // Pin to a release tag for reproducible dev environments.
    "ghcr.io/scottrigby/demotape/demotape:0.9.1": {}
  },

  // Persist large, version-stable downloads across container rebuilds.
  // Both volumes are write-once-read-many: same Chromium / voice across
  // any demotape version sharing the same Playwright/voice file.
  "mounts": [
    "source=demotape-dev-playwright,target=/usr/local/share/playwright,type=volume",
    "source=demotape-dev-voices,target=/usr/local/share/demotape/voices,type=volume"
  ],

  // After the feature pip-installs demotape from main, replace it with the
  // live source so edits in src/ take effect without reinstalling.
  "postCreateCommand": "pip install -e . --force-reinstall --no-deps && demotape --version"
}
