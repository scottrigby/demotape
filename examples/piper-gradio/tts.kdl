layout {
    pane split_direction="vertical" {
        // Main Interaction Pane: Runs the Podman container
        pane command="podman" {
            args "run" "-it" "--rm" "-p" "7860:7860" "-v" "$(pwd):/app:U,Z" "localhost/tts-demo"
            focus true
        }
        pane split_direction="horizontal" {
            // File Watcher: Monitor new .wav files in real-time
            pane command="watch" {
                args "-n" "1" "ls" "-lh" "*.wav"
            }
            // Optional: A clean shell for quick commands
            pane
        }
    }
    // Zellij UI components
    pane size=1 borderless=true {
        plugin location="zellij:compact-bar"
    }
}

