# Example .env file for showtape demos.
# Copy this to .env and fill in your values. Add .env to .gitignore.
# Shell environment always takes precedence over values here.
#
# Usage in YAML:  value: "${DEMO_PROJECT}"
#                 value: "${OPTIONAL_VAR:-fallback}"

DEMO_PROJECT=my-awesome-app
DEMO_ENVIRONMENT=production
DEMO_REGISTRY=ghcr.io/myorg
